+    def _frontier_cb(self, msg: PointCloud2) -> None:
+        self.frontiers = read_cloud(msg)
+
+    @staticmethod
+    def _status_field(data: str, key: str, default: str = "UNKNOWN") -> str:
+        token = f"{key}="
+        for part in data.split():
+            if part.startswith(token):
+                return part[len(token):]
+        return default
+
+    @staticmethod
+    def _parse_goal_key(data: str) -> Optional[Tuple[float, float, float]]:
+        match = re.search(r"goal_key=\(([^)]*)\)", data)
+        if not match:
+            return None
+        try:
+            values = [float(part.strip()) for part in match.group(1).split(",")]
+        except ValueError:
+            return None
+        if len(values) != 3:
+            return None
+        return values[0], values[1], values[2]
+
+    def _unreachable_region_key(self, x: float, y: float) -> Tuple[int, int]:
+        res = max(0.5, self.unreachable_region_resolution)
+        return (math.floor(x / res), math.floor(y / res))
+
+    def _prune_unreachable_blacklist(self, now: float) -> None:
+        ttl = max(1.0, self.unreachable_blacklist_ttl_sec)
+        self.unreachable_blacklisted_regions = {k: t for k, t in self.unreachable_blacklisted_regions.items() if now - t <= ttl}
+
+    def _is_unreachable_blacklisted(self, x: float, y: float, now: Optional[float] = None) -> bool:
+        now = self.get_clock().now().nanoseconds / 1e9 if now is None else now
+        self._prune_unreachable_blacklist(now)
+        return self._unreachable_region_key(x, y) in self.unreachable_blacklisted_regions
+
+    def _goal_to_path_status_cb(self, msg: String) -> None:
+        goal = self._parse_goal_key(msg.data)
+        if goal is None:
+            return
+        path_feasible = self._status_field(msg.data, "path_feasible", "true")
+        path_valid = self._status_field(msg.data, "path_valid", "true")
+        request_reselect = self._status_field(msg.data, "request_reselect", "false")
+        reject_reason = self._status_field(msg.data, "reject_reason", self._status_field(msg.data, "reason", "none"))
+        try:
+            endpoint_distance = float(self._status_field(msg.data, "endpoint_to_goal_distance", "0"))
+        except ValueError:
+            endpoint_distance = 0.0
+        infeasible = (
+            path_feasible == "false"
+            or path_valid == "false"
+            or request_reselect == "true"
+            or endpoint_distance > 1.5
+        )
+        key = (round(goal[0], 1), round(goal[1], 1), round(goal[2], 1))
+        if not infeasible:
+            self.unreachable_goal_fail_counts.pop(key, None)
+            return
+        count = self.unreachable_goal_fail_counts.get(key, 0) + 1
+        self.unreachable_goal_fail_counts[key] = count
+        if count < max(1, self.unreachable_path_fail_threshold):
+            return
+        now = self.get_clock().now().nanoseconds / 1e9
+        self._prune_unreachable_blacklist(now)
+        region = self._unreachable_region_key(goal[0], goal[1])
+        if region not in self.unreachable_blacklisted_regions:
+            self.unreachable_blacklist_event_count += 1
+        self.unreachable_blacklisted_regions[region] = now
+        self.last_reachability_reject_goal = f"({goal[0]:.2f},{goal[1]:.2f},{goal[2]:.2f})"
+        self.last_reachability_reject_reason = reject_reason
+
+    def _odom_cb(self, msg: Odometry) -> None:
+        self.odom = msg
+        p = msg.pose.pose.position
+        now = self.get_clock().now().nanoseconds / 1e9
+        point = (float(p.x), float(p.y), float(p.z), now)
+        if not self.odom_trail or math.dist(self.odom_trail[-1][:3], point[:3]) > 0.2:
+            self.odom_trail.append(point)
+            self.odom_trail = self.odom_trail[-80:]
+            self.visited_regions[self._region_key(float(p.x), float(p.y))] = now
+            self._prune_visited_regions(now)
+
+    def _complex_occupied_cb(self, msg: PointCloud2) -> None:
+        self.complex_grid.update_from_points(read_cloud(msg))
+        self.complex_env_received = True
+
+    def _boundary_distance(self, x: float, y: float) -> float:
+        return min(x - self.bounds["min_x"], self.bounds["max_x"] - x, y - self.bounds["min_y"], self.bounds["max_y"] - y)
+
+    def _boundary_inward_vector(self, x: float, y: float) -> Tuple[float, float]:
+        distances = {
+            "min_x": x - self.bounds["min_x"],
+            "max_x": self.bounds["max_x"] - x,
+            "min_y": y - self.bounds["min_y"],
+            "max_y": self.bounds["max_y"] - y,
+        }
+        side = min(distances, key=distances.get)
+        if side == "min_x":
+            return 1.0, 0.0
+        if side == "max_x":
+            return -1.0, 0.0
+        if side == "min_y":
+            return 0.0, 1.0
+        return 0.0, -1.0
+
+    def _boundary_direction_scores(self, ox: float, oy: float, x: float, y: float) -> Tuple[float, float]:
+        vx, vy = x - ox, y - oy
+        norm = math.hypot(vx, vy)
+        if norm < 1e-6:
+            return 0.0, 1.0
+        vx, vy = vx / norm, vy / norm
+        ix, iy = self._boundary_inward_vector(x, y)
+        inward = max(0.0, vx * ix + vy * iy)
+        tangent = math.sqrt(max(0.0, 1.0 - min(1.0, inward * inward)))
+        return inward, tangent
+
+    def _unknown_centroid(self, x: float, y: float) -> Tuple[float, float]:
+        nearby = [(fx, fy) for fx, fy, _ in self.frontiers if math.hypot(fx - x, fy - y) <= 3.0]
+        if nearby:
+            n = float(len(nearby))
+            return sum(p[0] for p in nearby) / n, sum(p[1] for p in nearby) / n
+        ix, iy = self._boundary_inward_vector(x, y)
+        return x + ix * self.inward_goal_offset, y + iy * self.inward_goal_offset
+
+    def _inward_goal(self, x: float, y: float, z: float) -> Tuple[Tuple[float, float, float], Tuple[float, float], bool]:
+        ux, uy = self._unknown_centroid(x, y)
+        dx, dy = ux - x, uy - y
+        if math.hypot(dx, dy) < 1e-3 or self._boundary_distance(x, y) < self.min_boundary_goal_distance * 1.5:
+            dx, dy = self._boundary_inward_vector(x, y)
+        norm = max(1e-6, math.hypot(dx, dy))
+        candidate = (x + dx / norm * self.inward_goal_offset, y + dy / norm * self.inward_goal_offset, z)
+        candidate = (
+            min(self.bounds["max_x"] - 0.25, max(self.bounds["min_x"] + 0.25, candidate[0])),
+            min(self.bounds["max_y"] - 0.25, max(self.bounds["min_y"] + 0.25, candidate[1])),
+            candidate[2],
+        )
+        if self._boundary_distance(candidate[0], candidate[1]) < self.min_boundary_goal_distance:
+            return (x, y, z), (ux, uy), False
+        if point_collision(self.obstacles, candidate, self.clearance).collides:
+            self.inward_goal_collision_reject_count += 1
+            return (x, y, z), (ux, uy), False
+        if self.complex_env_received and self.complex_grid.clearance(candidate) < self.min_wall_clearance_for_viewpoint:
+            self.inward_goal_collision_reject_count += 1
+            return (x, y, z), (ux, uy), False
+        return candidate, (ux, uy), True
+
+    def _boundary_goal_rejected(self, ox: float, oy: float, x: float, y: float, only_remaining_frontier: bool) -> bool:
+        boundary_distance = self._boundary_distance(x, y)
+        inward, tangent = self._boundary_direction_scores(ox, oy, x, y)
+        if only_remaining_frontier:
+            return False
+        hard_boundary = self.boundary_hard_reject and boundary_distance < self.min_boundary_goal_distance
+        tangent_boundary = tangent >= self.boundary_tangent_reject_threshold and inward < 0.35 and boundary_distance < self.min_boundary_goal_distance * 1.5
+        if hard_boundary or tangent_boundary:
+            self.boundary_goal_reject_count += 1
+            self.boundary_follow_reject_count += 1
+            return True
+        return False
+
+    def _region_key(self, x: float, y: float) -> Tuple[int, int]:
+        res = max(0.1, self.visited_region_resolution)
+        return (math.floor(x / res), math.floor(y / res))
+
+    def _task_region_key(self, x: float, y: float) -> Tuple[int, int]:
+        res = max(0.5, self.region_task_resolution)
+        return (math.floor(x / res), math.floor(y / res))
+
+    @staticmethod
+    def _region_id(key: Tuple[int, int]) -> str:
+        return f"R{key[0]}_{key[1]}"
+
+    def _prune_visited_regions(self, now: float) -> None:
+        horizon = max(1.0, self.visited_region_memory_sec)
+        self.visited_regions = {k: t for k, t in self.visited_regions.items() if now - t <= horizon}
+        self.visited_region_count = len(self.visited_regions)
+
+    def _estimate_information_gain(self, x: float, y: float) -> float:
+        near_15 = sum(1 for fx, fy, _ in self.frontiers if math.hypot(fx - x, fy - y) <= 1.5)
+        near_30 = sum(1 for fx, fy, _ in self.frontiers if math.hypot(fx - x, fy - y) <= 3.0)
+        if near_30 <= 0:
+            return 0.0
+        density = min(1.0, near_15 / max(1.0, near_30))
+        raw = min(1.0, near_30 / 18.0)
+        boundary_factor = 0.7 if self._boundary_distance(x, y) < self.boundary_penalty_distance else 1.0
+        return max(0.0, min(1.0, (0.75 * raw + 0.25 * density) * boundary_factor))
+
+    def _novelty_score(self, x: float, y: float, now: float) -> float:
+        if not self.visited_regions:
+            return 1.0
+        key = self._region_key(x, y)
+        if key not in self.visited_regions:
+            return 1.0
+        age = max(0.0, now - self.visited_regions[key])
+        return max(0.0, min(1.0, age / max(1.0, self.visited_region_memory_sec)))
+
+    def _cluster(self):
+        buckets: Dict[Tuple[int, int], List[Tuple[float, float, float]]] = {}
+        for x, y, z in self.frontiers:
+            key = (round(x / self.cluster_resolution), round(y / self.cluster_resolution))
+            buckets.setdefault(key, []).append((x, y, z))
+        clustered = []
+        for points in buckets.values():
+            n = float(len(points))
+            clustered.append((sum(p[0] for p in points) / n, sum(p[1] for p in points) / n, sum(p[2] for p in points) / n))
+        return clustered
+
+    def _build_region_tasks(self, ox: float, oy: float, now: float):
+        self._prune_unreachable_blacklist(now)
+        buckets: Dict[Tuple[int, int], List[Tuple[float, float, float]]] = {}
+        for x, y, z in self.frontiers:
+            buckets.setdefault(self._task_region_key(x, y), []).append((x, y, z))
+        tasks = []
+        for key, points in buckets.items():
+            n = float(len(points))
+            cx = sum(p[0] for p in points) / n
+            cy = sum(p[1] for p in points) / n
+            cz = sum(p[2] for p in points) / n
+            region_id = self._region_id(key)
+            frontier_count = len(points)
+            unknown_gain = min(1.0, frontier_count / 35.0)
+            density = min(1.0, frontier_count / max(1.0, self.region_task_resolution * self.region_task_resolution))
+            distance = math.hypot(cx - ox, cy - oy)
+            boundary_distance = self._boundary_distance(cx, cy)
+            boundary_penalty = max(0.0, self.min_boundary_goal_distance - boundary_distance) / max(0.1, self.min_boundary_goal_distance)
+            boundary_region_penalty = min(1.0, boundary_penalty)
+            visit_key = self._region_key(cx, cy)
+            novelty = self._novelty_score(cx, cy, now)
+            revisit_penalty = 1.0 - novelty if visit_key in self.visited_regions else 0.0
+            internal_unknown_gain = unknown_gain * max(0.0, 1.0 - 0.85 * boundary_region_penalty)
+            score = (
+                5.0 * internal_unknown_gain
+                + self.frontier_density_weight * density
+                + 2.0 * novelty
+                - self.distance_cost_weight * (distance / 30.0)
+                - 3.0 * revisit_penalty
+                - 5.0 * boundary_region_penalty
+            )
+            status = self.region_status.get(region_id, "active")
+            if self._is_unreachable_blacklisted(cx, cy, now):
+                status = "blacklisted"
+            elif frontier_count <= 1:
+                status = "completed"
+            elif boundary_penalty > 0.8 and score < 0.0:
+                status = "stale"
+            self.region_status[region_id] = status
+            tasks.append(
+                {
+                    "region_id": region_id,
+                    "region_center": (cx, cy, cz),
+                    "frontier_count": frontier_count,
+                    "unknown_gain_estimate": unknown_gain,
+                    "internal_unknown_gain": internal_unknown_gain,
+                    "frontier_density": density,
+                    "distance_to_uav": distance,
+                    "path_cost_estimate": distance,
+                    "revisit_penalty": revisit_penalty,
+                    "boundary_penalty": boundary_penalty,
+                    "boundary_region_penalty": boundary_region_penalty,
+                    "boundary_distance": boundary_distance,
+                    "score": score,
+                    "status": status,
+                }
+            )
+        return sorted(tasks, key=lambda t: t["score"], reverse=True)
+
+    def _forward_vector(self) -> Tuple[float, float]:
+        if len(self.odom_trail) >= 2:
+            ax, ay, _az, _at = self.odom_trail[-2]
+            bx, by, _bz, _bt = self.odom_trail[-1]
+            dx, dy = bx - ax, by - ay
+            norm = math.hypot(dx, dy)
