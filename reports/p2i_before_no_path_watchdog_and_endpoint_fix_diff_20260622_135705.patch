+            if key in METRIC_KEYS:
+                parsed[key] = coerce_value(value.strip())
+        elif active and line.startswith("P2") and "RESULT" in line:
+            continue
+        elif active and line.strip() == "":
+            active = False
+    return parsed
+
+
+def coerce_value(value: str) -> Any:
